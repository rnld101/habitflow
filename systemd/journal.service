[Unit]
Description=HabitFlow Journal Service
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/opt/habitflow/journal-service
EnvironmentFile=/opt/habitflow/journal-service/.env
ExecStart=/opt/habitflow/.venv/bin/uvicorn app:app --host 0.0.0.0 --port 8003
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
