[Unit]
Description=HabitFlow Auth Service
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/habitflow/auth-service

EnvironmentFile=/home/ubuntu/habitflow/auth-service/.env

ExecStart=/home/ubuntu/habitflow/auth-service/.venv/bin/uvicorn \
app:app \
--host 0.0.0.0 \
--port 8001

Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
